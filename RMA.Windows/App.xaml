<Application x:Class="RMA.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:RMA.Windows.Converters"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <ResourceDictionary>
      <!-- 1. Define Global Objects (Converters) FIRST -->
      <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
      <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
      <converters:GreaterThanConverter x:Key="GreaterThanConverter" />

      <SolidColorBrush x:Key="SnackbarBackgroundFillColorDefaultBrush" Color="#3A5A40" />
      <SolidColorBrush x:Key="SnackbarForegroundFillColorDefaultBrush" Color="#F3F6F4" />
      <SolidColorBrush x:Key="SnackbarCheckBoxBackgroundFillColorDefaultBrush" Color="#A3B18A" />

      <ResourceDictionary.MergedDictionaries>
        <!-- 2. UI Framework Styles -->
        <ui:ThemesDictionary Theme="Light" />
        <ui:ControlsDictionary />

        <!-- 3. Your Custom Styles (They now 'see' the converters above) -->
        <ResourceDictionary Source="Resources/DataTemplate.xaml" />
        <ResourceDictionary Source="Resources/Animations.xaml"/>
      </ResourceDictionary.MergedDictionaries>
      
    </ResourceDictionary>
  </Application.Resources>
</Application>