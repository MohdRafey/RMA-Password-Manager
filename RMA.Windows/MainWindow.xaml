<Window x:Class="RMA.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:RMA.Windows.ViewModels"
        Title="RMA" 
        Height="450" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

  <Window.DataContext>
    <vm:LoginViewModel />
  </Window.DataContext>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Window.Resources>

  <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#FDFDFD" 
                CornerRadius="24" 
                Padding="30" 
                Margin="20"
                BorderBrush="#11000000" 
                BorderThickness="1">
      <Border.Effect>
        <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="8" Color="#2D5A27"/>
      </Border.Effect>

      <Grid>
        <ui:Button Appearance="Secondary"
                           Content="{ui:SymbolIcon Dismiss24}"
                           Padding="0"
                           Width="30" Height="30"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Margin="0,-15,-15,0"
                           CornerRadius="15"
                           Click="CloseButton_Click">
          <ui:Button.Style>
            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
              <Setter Property="Opacity" Value="0.4"/>
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Opacity" Value="1"/>
                  <Setter Property="Background" Value="#FFE5E5"/>
                  <Setter Property="Foreground" Value="#D00000"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ui:Button.Style>
        </ui:Button>

        <StackPanel VerticalAlignment="Center">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsSetupMode}" Value="False">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <TextBlock Text=".RMA" FontSize="42" FontWeight="ExtraBold" Foreground="#3A5A40" HorizontalAlignment="Center"/>
          <TextBlock Text="Password Manager" FontSize="9" FontWeight="Bold" Foreground="#A3B18A" HorizontalAlignment="Center" Margin="0,-5,0,30"/>

          <TextBlock Text="Master PIN" Foreground="#3A5A40" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold"/>
          <StackPanel>
            <!-- Counter for the PIN -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,6">
              <!-- This one changes color and number -->
              <TextBlock x:Name="LoginCounter" 
               Text="0" 
               FontSize="10" 
               FontWeight="Bold" 
               Foreground="#889674"/>

              <!-- This one stays static -->
              <TextBlock Text="/6" 
               FontSize="10" 
               FontWeight="Bold" 
               Foreground="{Binding Foreground, ElementName=LoginCounter}"/>
            </StackPanel>

            <ui:PasswordBox x:Name="LoginPinBox" 
                    PlaceholderText="Enter 6-digit PIN" 
                    PasswordChar="●"
                    MaxLength="6"
                    Margin="0,0,0,15"
                    PasswordChanged="LoginPinBox_PasswordChanged"
                    PreviewTextInput="LoginPinBox_PreviewTextInput">
              <ui:PasswordBox.InputBindings>
                <KeyBinding Key="Enter" 
                        Command="{Binding AuthenticateCommand}" 
                        CommandParameter="{Binding ElementName=LoginPinBox}"/>
              </ui:PasswordBox.InputBindings>
            </ui:PasswordBox>
          </StackPanel>
          <ui:Button Content="Login" 
                   Command="{Binding AuthenticateCommand}"
                   CommandParameter="{Binding ElementName=LoginPinBox}"
                   Appearance="Primary" 
                   HorizontalAlignment="Stretch" 
                   Height="45"
                   Margin="0,0,0,10"/>

          <ui:Button Content="Login Using QR" 
                   Icon="{ui:SymbolIcon QrCode24}"
                   Appearance="Secondary" 
                   HorizontalAlignment="Stretch" 
                   Height="40"
                   Margin="0,0,0,20"/>

          <TextBlock HorizontalAlignment="Center">
            <Run Text="New User?" Foreground="#6B705C" FontSize ="10"/>
            <Hyperlink Command="{Binding ToggleSetupCommand}" Foreground="#3A5A40" FontSize ="12" TextDecorations="None">
                Create a New Vault
            </Hyperlink>
          </TextBlock>
        </StackPanel>
        <StackPanel VerticalAlignment="Center" 
            Visibility="{Binding IsSetupMode, Converter={StaticResource BoolToVis}}">

          <TextBlock Text="Create Identity" FontSize="32" FontWeight="Bold" Foreground="#3A5A40" HorizontalAlignment="Center"/>

          <TextBlock Text="Vault Name" Foreground="#3A5A40" Margin="0,15,0,8" FontSize="12" FontWeight="SemiBold"/>
          <ui:TextBox x:Name="VaultNameBox" 
                PlaceholderText="e.g. Ray_Personal" 
                Icon="{ui:SymbolIcon Person24}"
                Margin="0,0,0,10"/>

          <ui:PasswordBox x:Name="SetupPinBox" PlaceholderText="Choose 6-digit PIN" Margin="0,0,0,10"/>
          <ui:PasswordBox x:Name="ConfirmPinBox" PlaceholderText="Confirm PIN" Margin="0,0,0,20"/>

          <ui:Button Content="Initialize Security" 
               Command="{Binding CreateVaultCommand}"
               CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}}"
               Appearance="Success" 
               HorizontalAlignment="Stretch" 
               Height="45"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>