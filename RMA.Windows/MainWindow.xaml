<Window x:Class="RMA.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:RMA.Windows.ViewModels"
        Title="RMA" 
        Height="520" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

  <Window.DataContext>
    <vm:LoginViewModel />
  </Window.DataContext>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <Style x:Key="ValidatedTextBoxStyle" TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
      <Style.Triggers>
        <DataTrigger Binding="{Binding IdHasError}" Value="True">
          <Setter Property="BorderBrush" Value="#D00000"/>
          <Setter Property="BorderThickness" Value="1.5"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ValidatedPasswordBoxStyle" TargetType="ui:PasswordBox" BasedOn="{StaticResource {x:Type ui:PasswordBox}}">
      <Style.Triggers>
        <DataTrigger Binding="{Binding PinHasError}" Value="True">
          <Setter Property="BorderBrush" Value="#D00000"/>
          <Setter Property="BorderThickness" Value="1.5"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="RmaPrimaryButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
      <Setter Property="Appearance" Value="Primary"/>
      <Setter Property="Background" Value="#3A5A40"/>
      <Setter Property="BorderBrush" Value="#3A5A40"/>

      <Style.Triggers>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="#526D59"/>
          <Setter Property="BorderBrush" Value="#526D59"/>
          <Setter Property="Foreground" Value="#A3B18A"/>
          <Setter Property="Opacity" Value="0.7"/>
        </Trigger>

        <MultiTrigger>
          <MultiTrigger.Conditions>
            <Condition Property="IsMouseOver" Value="True"/>
            <Condition Property="IsEnabled" Value="False"/>
          </MultiTrigger.Conditions>
          <Setter Property="Background" Value="#526D59"/>
        </MultiTrigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="MainBorder" Background="#FDFDFD" 
                CornerRadius="24" 
                Padding="30" 
                Margin="20"
                BorderBrush="#11000000" 
                BorderThickness="1">
      <Border.Effect>
        <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="8" Color="#2D5A27"/>
      </Border.Effect>
      <Border.RenderTransform>
        <TranslateTransform X="0" Y="0"/>
      </Border.RenderTransform>

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:Button Appearance="Secondary"
                   Content="{ui:SymbolIcon Dismiss24}"
                   Padding="0"
                   Width="30" Height="30"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,-15,-15,0"
                   CornerRadius="15"
                   Click="CloseButton_Click">
          <ui:Button.Style>
            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
              <Setter Property="Opacity" Value="0.4"/>
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Opacity" Value="1"/>
                  <Setter Property="Background" Value="#FFE5E5"/>
                  <Setter Property="Foreground" Value="#D00000"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ui:Button.Style>
        </ui:Button> <!-- Close Button -->

        <ui:Button Appearance="Transparent"
       Content="{ui:SymbolIcon ArrowLeft24}"
       Padding="0" Width="30" Height="30"
       HorizontalAlignment="Right" VerticalAlignment="Top"
       Margin="0,-15,20,0"
       CornerRadius="15"
       Command="{Binding ToggleSetupCommand}"
       Visibility="{Binding IsSetupMode, Converter={StaticResource BoolToVis}}">
          <ui:Button.Style>
            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
              <Setter Property="Opacity" Value="0.4"/>
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Opacity" Value="1"/>
                  <Setter Property="Background" Value="#E9ECEF"/>
                  <Setter Property="Foreground" Value="#3A5A40"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ui:Button.Style>
        </ui:Button> <!-- Back Button-->

        <StackPanel Grid.Row="0" Margin="0,10,0,20">
          <TextBlock Text=".RMA" 
                   FontSize="42" 
                   FontWeight="ExtraBold" 
                   Foreground="#3A5A40" 
                   HorizontalAlignment="Center"/>
          <TextBlock Text="Password Manager" 
                   FontSize="9" 
                   FontWeight="Bold" 
                   Foreground="#A3B18A" 
                   HorizontalAlignment="Center" 
                   Margin="0,-5,0,0"/>
        </StackPanel> <!--Logo-->

        <Grid Grid.Row="1" VerticalAlignment="Center">
          <StackPanel VerticalAlignment="Center" Visibility="{Binding IsSetupMode, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSetupMode}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>

            <TextBlock Text="User ID" Foreground="#3A5A40" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold"/>
            <ui:TextBox x:Name="LoginUserIdBox" 
                                Style="{StaticResource ValidatedTextBoxStyle}"
                                IsEnabled="{Binding CanLogin}"
                                PlaceholderText="Enter your User ID" 
                                Icon="{ui:SymbolIcon Person24}"
                                Margin="0,0,0,15"
                                Text="{Binding UserIdInput, UpdateSourceTrigger=PropertyChanged}"/>
            
            <TextBlock Text="Master PIN" Foreground="#3A5A40" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold"/>
            <ui:PasswordBox x:Name="LoginPinBox" 
                                    Style="{StaticResource ValidatedPasswordBoxStyle}"
                                    IsEnabled="{Binding CanLogin}"
                                    PlaceholderText="Enter 6-digit PIN" 
                                    PasswordChanged="LoginPinBox_PasswordChanged"
                                    PasswordChar="●"
                                    MaxLength="6"
                                    Margin="0,0,0,15"
                                    PreviewTextInput="LoginPinBox_PreviewTextInput">
            <ui:PasswordBox.InputBindings>
              <KeyBinding Key="Enter" 
                                        Command="{Binding AuthenticateCommand}" 
                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}}"/>
            </ui:PasswordBox.InputBindings>
          </ui:PasswordBox>
            
            <TextBlock Text="{Binding ErrorMessage}"                      
                               Foreground="#D00000" 
                               FontSize="14" 
                               FontWeight="Normal"
                               HorizontalAlignment="Left" 
                               Margin="0,0,0,10"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
            
            <ui:Button Command="{Binding AuthenticateCommand}"
            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}}"
            IsEnabled="{Binding CanLogin}"
            Style="{StaticResource RmaPrimaryButtonStyle}"
            HorizontalAlignment="Stretch" 
            Height="50"
            Margin="0,0,0,10">
            <Grid>
              <TextBlock Text="Login" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsAuthenticating}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed"/>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding IsLockedOut}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>

              <Grid Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"
      Visibility="{Binding IsAuthenticating, Converter={StaticResource BoolToVis}}">
                <Path Stroke="#3A5A40" 
          StrokeThickness="2" 
          StrokeStartLineCap="Round" 
          StrokeEndLineCap="Round"
          Data="M 10,1 A 9,9 0 1 1 2,14" 
          RenderTransformOrigin="0.5,0.5">
                  <Path.RenderTransform>
                    <RotateTransform x:Name="SimpleSpinnerRotate"/>
                  </Path.RenderTransform>
                  <Path.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetName="SimpleSpinnerRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="0" To="360" Duration="0:0:0.8" 
                                         RepeatBehavior="Forever"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </EventTrigger>
                  </Path.Triggers>
                </Path>
              </Grid>

              <StackPanel Orientation="Horizontal" Visibility="{Binding IsLockedOut, Converter={StaticResource BoolToVis}}">
                <ui:SymbolIcon Symbol="LockClosed24" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding LockoutSeconds, StringFormat='Locked ({0}s)'}" VerticalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </ui:Button> <!--Login Button-->
            <ui:Button Content="Login Using QR" 
           IsEnabled="{Binding IsAuthenticating, Converter={StaticResource InverseBooleanConverter}}"
           Appearance="Secondary" 
           HorizontalAlignment="Stretch" 
           Height="40"
           Margin="0,0,0,20"/> <!--Authenticate Using QR-->
            
            <TextBlock HorizontalAlignment="Center">
            <Run Text="New User?" Foreground="#6B705C" FontSize ="10"/>
            <Hyperlink Command="{Binding ToggleSetupCommand}" Foreground="#3A5A40" FontSize ="12" TextDecorations="None">
                Create a New Vault
            </Hyperlink>
          </TextBlock> <!--Info Box  + Link to New Vault-->
          </StackPanel>

          <StackPanel VerticalAlignment="Center" Visibility="{Binding IsSetupMode, Converter={StaticResource BoolToVis}}">
            
            <TextBlock Text="Vault Name" Foreground="#3A5A40" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold"/>
            <ui:TextBox PlaceholderText="e.g. MyPersonalVault" 
                Icon="{ui:SymbolIcon folder24}"
                Margin="0,0,0,15"
                Text="{Binding SetupVaultName, UpdateSourceTrigger=PropertyChanged}">
              <ui:TextBox.Style>
                <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding SetupNameError}" Value="True">
                      <Setter Property="BorderBrush" Value="#D00000"/>
                      <Setter Property="BorderThickness" Value="1.5"/>
                    </DataTrigger>
                  </Style.Triggers>
              </Style>
              </ui:TextBox.Style>
            </ui:TextBox>

            <Grid Margin="0,0,0,8">
              <TextBlock Text="Master PIN" Foreground="#3A5A40" FontSize="12" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Strength: " Foreground="#A3B18A" FontSize="10" VerticalAlignment="Bottom"/>
                <TextBlock Text="{Binding SetupStrengthText}" Foreground="{Binding SetupStrengthColor}" FontSize="10" FontWeight="Bold" VerticalAlignment="Bottom"/>
              </StackPanel>
            </Grid>
            <ui:PasswordBox x:Name="SetupPinBox" 
                     PasswordChanged="SetupPinBox_PasswordChanged"
                     PlaceholderText="Choose 6-digit PIN" 
                     MaxLength="6"
                     Margin="0,0,0,15">
              <ui:PasswordBox.Style>
                <Style TargetType="ui:PasswordBox" BasedOn="{StaticResource {x:Type ui:PasswordBox}}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding SetupPinError}" Value="True">
                      <Setter Property="BorderBrush" Value="#D00000"/>
                      <Setter Property="BorderThickness" Value="1.5"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </ui:PasswordBox.Style>
            </ui:PasswordBox>

            <TextBlock Text="Confirm PIN" Foreground="#3A5A40" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold"/>
            <ui:PasswordBox x:Name="ConfirmPinBox" 
                     PasswordChanged="ConfirmPinBox_PasswordChanged"
                     PlaceholderText="Re-enter PIN" 
                     MaxLength="6"
                     Margin="0,0,0,15">
              <ui:PasswordBox.Style>
                <Style TargetType="ui:PasswordBox" BasedOn="{StaticResource {x:Type ui:PasswordBox}}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding SetupConfirmError}" Value="True">
                      <Setter Property="BorderBrush" Value="#D00000"/>
                      <Setter Property="BorderThickness" Value="1.5"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </ui:PasswordBox.Style>
            </ui:PasswordBox>

            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="#D00000" 
                       FontSize="14" 
                       FontWeight="Normal"
                       HorizontalAlignment="Left" 
                       Margin="0,0,0,10" 
                       TextWrapping="Wrap" 
                       TextAlignment="Center" 
                       Height="40"/>
            
            <ui:Button Content="Initialize Vault" 
                       Command="{Binding CreateVaultCommand}"
                       Style="{StaticResource RmaPrimaryButtonStyle}"
                       HorizontalAlignment="Stretch" Height="50"/>
          </StackPanel>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>