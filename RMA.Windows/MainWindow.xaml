<Window x:Class="RMA.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:RMA.Windows.ViewModels"
        Title="RMA" 
        Height="450" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

  <Window.DataContext>
    <vm:LoginViewModel />
  </Window.DataContext>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Window.Resources>

  <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#FDFDFD" 
                CornerRadius="24" 
                Padding="30" 
                Margin="20"
                BorderBrush="#11000000" 
                BorderThickness="1">
      <Border.Effect>
        <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="8" Color="#2D5A27"/>
      </Border.Effect>

      <Grid>
        <ui:Button Appearance="Secondary"
                           Content="{ui:SymbolIcon Dismiss24}"
                           Padding="0"
                           Width="30" Height="30"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Margin="0,-15,-15,0"
                           CornerRadius="15"
                           Click="CloseButton_Click">
          <ui:Button.Style>
            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
              <Setter Property="Opacity" Value="0.4"/>
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Opacity" Value="1"/>
                  <Setter Property="Background" Value="#FFE5E5"/>
                  <Setter Property="Foreground" Value="#D00000"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ui:Button.Style>
        </ui:Button>

        <StackPanel VerticalAlignment="Center">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsSetupMode}" Value="False">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <TextBlock Text=".RMA" FontSize="42" FontWeight="ExtraBold" Foreground="#3A5A40" HorizontalAlignment="Center"/>
          <TextBlock Text="Password Manager" FontSize="9" FontWeight="Bold" Foreground="#A3B18A" HorizontalAlignment="Center" Margin="0,-5,0,30"/>

          <TextBlock Text="Master PIN" Foreground="#3A5A40" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold"/>
          <ui:PasswordBox x:Name="LoginPinBox" 
                PlaceholderText="••••••••••••••••••" 
                PasswordChar="●"
                MaxLength="6"
                FontSize="18"
                Margin="0,0,0,15"
                HorizontalContentAlignment="Left"
                Padding="12,0,45,0" 
                ClearButtonEnabled="False"
                RevealButtonEnabled="True" />

          <ui:Button Content="Login" 
                   Command="{Binding AuthenticateCommand}"
                   CommandParameter="{Binding ElementName=LoginPinBox}"
                   Appearance="Primary" 
                   HorizontalAlignment="Stretch" 
                   Height="45"
                   Margin="0,0,0,10"/>

          <ui:Button Content="Login Using QR" 
                   Icon="{ui:SymbolIcon QrCode24}"
                   Appearance="Secondary" 
                   HorizontalAlignment="Stretch" 
                   Height="40"
                   Margin="0,0,0,20"/>

          <TextBlock HorizontalAlignment="Center">
            <Run Text="New User?" Foreground="#6B705C" FontSize ="10"/>
            <Hyperlink Command="{Binding ToggleSetupCommand}" Foreground="#3A5A40" FontSize ="10" TextDecorations="None">
                Create a New Vault
            </Hyperlink>
          </TextBlock>
        </StackPanel>
        <StackPanel VerticalAlignment="Center" 
                Visibility="{Binding IsSetupMode, Converter={StaticResource BoolToVis}}">

          <TextBlock Text="Setup Vault" FontSize="32" FontWeight="Bold" Foreground="#3A5A40" HorizontalAlignment="Center"/>
          <TextBlock Text="Choose a 6-digit Master PIN" FontSize="11" Foreground="#A3B18A" HorizontalAlignment="Center" Margin="0,5,0,25"/>

          <ui:PasswordBox x:Name="SetupPinBox" PlaceholderText="New PIN" Margin="0,0,0,10"/>
          <ui:PasswordBox x:Name="ConfirmPinBox" PlaceholderText="Confirm PIN" Margin="0,0,0,20"/>

          <ui:Button Content="Initialize Security" 
                   Command="{Binding CreateVaultCommand}"
                   Appearance="Success" 
                   HorizontalAlignment="Stretch" 
                   Height="45"/>

          <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0">
            <Hyperlink Command="{Binding ToggleSetupCommand}" Foreground="#A3B18A" TextDecorations="None">
                Wait, I have a PIN. Go back.
            </Hyperlink>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>