<ui:FluentWindow x:Class="RMA.Windows.Views.AddCredentialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:RMA.Windows.ViewModels"
        xmlns:models="clr-namespace:RMA.Windows.Models"
        xmlns:helpers="clr-namespace:RMA.Windows.Helpers"
        Title="Add New Credential" 
        Height="720" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStyle="SingleBorderWindow"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

  <Window.Resources>
    <!-- Your existing inline styles -->
      <Style x:Key="AutoSuggestFieldStyle" TargetType="ui:AutoSuggestBox" BasedOn="{StaticResource {x:Type ui:AutoSuggestBox}}">
        <Setter Property="Height" Value="38"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
      </Style>

    <Style x:Key="StandardTextBoxStyle" TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
      <Setter Property="Height" Value="38"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
  </Window.Resources>
  
  <!-- THIS IS THE FIX -->
  <ui:FluentWindow.DataContext>
    <vm:AddCredentialViewModel/>
  </ui:FluentWindow.DataContext>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- 1. MODERN TITLE BAR -->
    <ui:TitleBar Grid.Row="0" Title="Vault Editor" Icon="Add24"/>

    <!-- 2. CONTENT AREA -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <Border Padding="30,15,30,30">
        <StackPanel>
          <!-- Header -->
          <Grid Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="#103A5A40" CornerRadius="8" Width="48" Height="48">
              <ui:SymbolIcon Symbol="ShieldAdd24" FontSize="28" Foreground="#3A5A40"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
              <TextBlock Text="Add Credential" FontSize="20" FontWeight="Bold" Foreground="#3A5A40"/>
            </StackPanel>
          </Grid>

          <!-- SECTION 1: SERVICE INFORMATION -->
          <TextBlock Text="SERVICE INFORMATION" FontSize="10" FontWeight="Black" Foreground="#A3B18A" Margin="2,0,0,10"/>
          <Border Background="#05000000" CornerRadius="8" Padding="15" Margin="0,0,0,20" ClipToBounds="False">
            <StackPanel ClipToBounds="False">
              <!-- Searchable Service Name -->
              <ui:AutoSuggestBox x:Name="ServiceSearchBox"
                   Style="{StaticResource AutoSuggestFieldStyle}"
                   PlaceholderText="Service Name (e.g. GitHub)" 
                   OriginalItemsSource="{Binding AllTemplates}"
                   DisplayMemberPath="Name"
                   Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                   SuggestionChosen="ServiceSearchBox_SuggestionChosen"
                   PreviewKeyDown="ServiceSearchBox_PreviewKeyDown"
                   Margin="0,0,0,12">
                <ui:AutoSuggestBox.Resources>
                  <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="GreenYellow" />
                </ui:AutoSuggestBox.Resources>
              </ui:AutoSuggestBox>
              <ui:TextBox
                Style="{StaticResource StandardTextBoxStyle}"
                PlaceholderText="Service URL (optional)" 
                Icon="{ui:SymbolIcon Globe24}"
                Text="{Binding ServiceUrl, UpdateSourceTrigger=PropertyChanged}" 
                Margin="0,0,0,12"/>

              <ui:TextBox PlaceholderText="Category / Tag (Social, Work, etc.)" 
                Icon="{ui:SymbolIcon Tag24}"
                Text="{Binding Tag, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
          </Border>

          <!-- SECTION 2: LOGIN INFO -->
          <TextBlock Text="ACCOUNT DETAILS" FontSize="10" FontWeight="Black" Foreground="#A3B18A" Margin="2,0,0,10"/>
          <Border Background="#05000000" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
              <ui:TextBox PlaceholderText="Username / Email" 
                                        Icon="{ui:SymbolIcon Person24}"
                                        Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                        Margin="0,0,0,12" />

              <!-- PassBox remains named so we can pass it as a CommandParameter -->
              <ui:PasswordBox x:Name="PassBox" 
                                            PlaceholderText="Password" 
                                            Margin="0,0,0,8" />
              <!-- Notes Block -->
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,12,8">
                <TextBlock x:Name="NotesCounter" 
                  Text="0" 
                  FontSize="9" 
                  FontWeight="Bold" 
                  Foreground="#889674"
                  RenderTransformOrigin="0.5,0.5">
                  <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="CounterScale" ScaleX="1" ScaleY="1"/>
                  </TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock Text="/120" 
                  FontSize="9" 
                  FontWeight="Bold" 
                  Foreground="{Binding Foreground, ElementName=NotesCounter}"/>
              </StackPanel>

              <ui:TextBox x:Name="NotesBox"
                Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Notes (optional)"
                Icon="{ui:SymbolIcon Note24}"
                Height="75" 
                AcceptsReturn="True" 
                TextWrapping="Wrap" 
                VerticalContentAlignment="Top"
                Padding="8,8,8,8" 
                MaxLength="120" 
                TextChanged="NotesBox_TextChanged"/>
            </StackPanel>
          </Border>

          <!-- FOOTER INFO -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,25" Opacity="0.7">
            <ui:SymbolIcon Symbol="LockClosed16" FontSize="12" Margin="0,0,5,0" Foreground="#3A5A40"/>
            <TextBlock Text="AES-256 Bit Encryption Active" FontSize="10" FontWeight="SemiBold" Foreground="#3A5A40"/>
          </StackPanel>

          <!-- ACTION BUTTONS -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <ui:Button Content="Cancel" 
                                   Grid.Column="0"
                                   Appearance="Secondary" 
                                   HorizontalAlignment="Stretch" 
                                   Height="42"
                                   Margin="0,0,8,0"
                                   Click="CloseButton_Click"/>

            <!-- Bound to SaveCommand as per ViewModel naming convention -->
            <ui:Button Content="Create Entry" 
                                   Grid.Column="1"
                                   Appearance="Primary" 
                                   HorizontalAlignment="Stretch" 
                                   Height="42"
                                   FontWeight="Bold"
                                   Command="{Binding SaveCommand}"
                                   CommandParameter="{Binding ElementName=PassBox}">
              <ui:Button.Icon>
                <ui:SymbolIcon Symbol="Checkmark24"/>
              </ui:Button.Icon>
            </ui:Button>
          </Grid>
        </StackPanel>
      </Border>
    </ScrollViewer>
  </Grid>
</ui:FluentWindow>