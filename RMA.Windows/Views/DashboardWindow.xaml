<ui:FluentWindow x:Class="RMA.Windows.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RMA.Windows.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="RMA Dashboard" Height="750" Width="1100" MinWidth="1100" MinHeight="750"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True" 
        WindowBackdropType="Mica">

  <!-- Design-time DataContext for Intellisense -->
  <d:Window.DataContext>
    <vm:DashboardViewModel />
  </d:Window.DataContext>

  <Grid>
    <Grid x:Name="VaultContent">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="30" />
      </Grid.RowDefinitions>

      <!-- 1. TOP MENU STRIP -->
      <Grid Grid.Row="0" Background="#3A5A40" Height="40" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,20,0">
          <TextBlock Text=".RMA" FontWeight="Black" FontSize="24" Foreground="#F3F6F4" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <ui:Button Content="Vault" Foreground="#F3F6F4" Appearance="Transparent" Padding="12,4" Margin="0,0,5,0" FontSize="12"/>
          <ui:Button Content="Import" Foreground="#F3F6F4" Appearance="Transparent" Padding="12,4" Margin="0,0,5,0" FontSize="12"/>
          <ui:Button Content="Settings" Foreground="#F3F6F4" Appearance="Transparent" Padding="12,4" Margin="0,0,5,0" FontSize="12"/>
          <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,8" />
          <Border Background="#E9EDC9" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="14" Foreground="#3A5A40" Margin="0,0,5,0"/>
              <TextBlock Text="ENCRYPTED" FontSize="9" FontWeight="Bold" Foreground="#3A5A40" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Window Controls -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,5,0">
          <ui:Button Content="{ui:SymbolIcon LockClosed24}" Width="30" Height="30" Padding="0" Margin="2,0" CornerRadius="15" Background="Black" Foreground="#F3F6F4" Click="LockVault_Click"/>
          <ui:Button Appearance="Secondary" Content="{ui:SymbolIcon Subtract24}" Width="30" Height="30" Padding="0" Margin="2,0" CornerRadius="15" Click="MinimizeButton_Click"/>
          <ui:Button Appearance="Secondary" Content="{ui:SymbolIcon Maximize24}" Width="30" Height="30" Padding="0" Margin="2,0" CornerRadius="15" Click="MaximizeButton_Click"/>
          <ui:Button Appearance="Secondary" Content="{ui:SymbolIcon Dismiss24}" Width="30" Height="30" Padding="0" Margin="2,0" CornerRadius="15" Click="CloseButton_Click"/>
        </StackPanel>
      </Grid>

      <!-- 2. MAIN BODY -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#F3F6F4" BorderBrush="#DCE0DD" BorderThickness="0,0,1,0">
          <Grid Margin="20">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,30">
              <TextBlock Text="PERSONAL VAULT" FontSize="10" FontWeight="Bold" Foreground="#A3B18A" Margin="4,0,0,0"/>
              <!-- BINDING UPDATED HERE -->
              <TextBlock Text="{Binding VaultName, FallbackValue='Vault'}" FontSize="24" FontWeight="Bold" Foreground="#3A5A40"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
              <ui:Button Content="Credentials" Icon="{ui:SymbolIcon Key24}" Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8" Margin="0,0,0,4"/>
              <ui:Button Content="Private Notes" Icon="{ui:SymbolIcon Note24}" Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8" Margin="0,0,0,4"/>
              <ui:Button Content="Financials" Icon="{ui:SymbolIcon Payment24}" Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,8" Margin="0,0,0,4"/>
            </StackPanel>

            <StackPanel Grid.Row="2">
              <TextBlock Text="SYSTEM TEST" FontSize="9" FontWeight="Bold" Foreground="#A3B18A" Margin="4,0,0,5"/>
              <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" Content="Info" Icon="{ui:SymbolIcon Info24}" 
                   Appearance="Transparent" Click="TestInfo_Click" Margin="0,0,2,0"/>

                <ui:Button Grid.Column="1" Content="Warn" Icon="{ui:SymbolIcon Warning24}" 
                   Appearance="Transparent" Click="TestWarn_Click" Margin="2,0,2,0"/>

                <ui:Button Grid.Column="2" Content="Error" Icon="{ui:SymbolIcon ErrorCircle24}" 
                   Appearance="Transparent" Click="TestError_Click" Margin="2,0,0,0"/>
              </Grid>
              <ui:Button Content="Add New Item" Icon="{ui:SymbolIcon Add24}" Appearance="Primary" HorizontalAlignment="Stretch" Height="40" Margin="0,0,0,15" FontWeight="SemiBold" Command="{Binding AddCredentialCommand}"/>
              <ui:Button Content="Lock Vault" Icon="{ui:SymbolIcon LockClosed24}" Appearance="Danger" HorizontalAlignment="Stretch" Click="LockVault_Click"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Border Grid.Column="1" Background="#FFFFFF" Padding="40">
          <Grid Margin="30,0,30,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TextBox Grid.Row="0" PlaceholderText="Search your vault..." Icon="{ui:SymbolIcon Search24}" Margin="0,0,0,30"/>
            <!-- 1. The list of cards -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding Credentials}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource CredentialCardTemplate}" Margin="0,0,15,15"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- 2. ADD THE "EMPTY STATE" TEXTBLOCK HERE -->
            <TextBlock Grid.Row="1" 
                   Text="Your vault is empty. Click 'Add New Item' to start."
                   Foreground="Gray"
                   FontSize="14"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <!-- When Credentials count is 0, show this message -->
                    <DataTrigger Binding="{Binding Credentials.Count}" Value="0">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="2" Background="#3A5A40" BorderBrush="#2F4F35" BorderThickness="0,1,0,0">
        <Grid Margin="15,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <ui:SymbolIcon Symbol="Copy24" FontSize="12" Foreground="#A3B18A" Margin="0,0,5,0"/>
            <TextBlock Text="2026 Mohd Rafey. All rights reserved." 
                           Foreground="#F3F6F4" FontSize="10" Opacity="0.8" VerticalAlignment="Center"/>
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusText}" 
                           Foreground="#E9EDC9" FontSize="10" FontWeight="SemiBold" 
                           Margin="0,0,20,0" VerticalAlignment="Center"/>

            <ui:SymbolIcon Symbol="Clock24" FontSize="12" Foreground="#F3F6F4" Margin="10,0,5,0"/>
            <TextBlock Text="{Binding CurrentTime, FallbackValue='00:00'}" 
           Foreground="#F3F6F4" 
           FontSize="11" 
           FontWeight="Bold" 
           VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- The Lock Overlay -->
    <Grid x:Name="LockOverlay" Visibility="Collapsed" Panel.ZIndex="9999">
      <Border Background="#99000000" />
      <Border Background="#F3F6F4" Width="380" Height="280" CornerRadius="20" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#3A5A40" BorderThickness="0.5">
        <StackPanel VerticalAlignment="Center" Margin="30">
          <ui:SymbolIcon Symbol="ShieldLock24" FontSize="44" Foreground="#3A5A40" Margin="0,0,0,15"/>
          <TextBlock Text="VAULT LOCKED" FontWeight="Black" FontSize="18" Foreground="#1B261C" HorizontalAlignment="Center" Margin="0,0,0,25"/>

          <ui:PasswordBox x:Name="UnlockPasswordBox" PlaceholderText="Enter PIN" PasswordChar="●" MaxLength="6" KeyDown="UnlockPasswordBox_KeyDown" Margin="0,0,0,20"/>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:Button Content="UNLOCK" Grid.Column="0" Appearance="Primary" Margin="0,0,5,0" HorizontalAlignment="Stretch" Height="40" FontWeight="Bold" Click="Unlock_Click"/>
            <ui:Button Content="EXIT APP" Grid.Column="1" Appearance="Secondary" Margin="5,0,0,0" HorizontalAlignment="Stretch" Height="40" FontWeight="Bold" Click="CloseButton_Click"/>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Grid>
      <ui:SnackbarPresenter x:Name="DashboardSnackbar" 
                          VerticalAlignment="Bottom" 
                          HorizontalAlignment="Right"
                          MaxWidth="550"
                          MinWidth="450"
                          Margin="0,0,25,55"
                          Panel.ZIndex="10000"/>
    </Grid>
  </Grid>
</ui:FluentWindow>