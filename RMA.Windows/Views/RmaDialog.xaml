<Window x:Class="RMA.Windows.Views.RmaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Notification" Width="Auto" 
        Height="Auto"
        SizeToContent="WidthAndHeight" 
        MinWidth="380" 
        MaxWidth="550" 
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None"
        AllowsTransparency="True" 
        Background="Transparent">

  <Grid>
    <Border Background="#FDFDFD" 
        CornerRadius="24" 
        Padding="30"  Margin="20"
            BorderBrush="#11000000" 
        BorderThickness="1">
      <Border.Effect>
        <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="8" Color="#3A5A40"/>
      </Border.Effect>

      <Grid>
        <ui:Button Appearance="Secondary"
                   Content="{ui:SymbolIcon Dismiss24}"
                   Padding="0"
                   Width="30" Height="30"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,-15,-15,0" 
                   CornerRadius="15"
                   Click="CloseButton_Click">
          <ui:Button.Style>
            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
              <Setter Property="Opacity" Value="0.4"/>
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Opacity" Value="1"/>
                  <Setter Property="Background" Value="#FFE5E5"/>
                  <Setter Property="Foreground" Value="#D00000"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ui:Button.Style>
        </ui:Button>
        
        <StackPanel VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <ui:SymbolIcon x:Name="TypeIcon" Symbol="Info24" FontSize="20" Margin="0,0,8,0"/>
            <TextBlock x:Name="TitleTxt" Text="TITLE" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
          </StackPanel>

          <TextBlock x:Name="MessageTxt" Text="Your message goes here." TextWrapping="Wrap" 
                               TextAlignment="Center" FontSize="13" Foreground="#555555" Margin="0,0,0,20"/>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <ui:Button x:Name="CancelBtn" Content="Cancel" Width="90" Margin="0,0,10,0"
                                   Appearance="Secondary" Visibility="Collapsed" Click="CancelBtn_Click"/>
            <ui:Button x:Name="OkBtn" Content="Okay" Width="100" 
                                   Appearance="Primary" Click="OkBtn_Click"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>